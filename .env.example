# Required for normal local use.
PFA_BIND_HOST=127.0.0.1
PFA_BIND_PORT=8088
PFA_SECRET_KEY=change-me

# Application identity.
PFA_APP_NAME=Protected File Analyzer

# Default prebuilt images for normal deployment.
PFA_WEB_IMAGE=ghcr.io/daniel-brodsky/protected-file-analyzer-docker-web:0.1.0
PFA_WORKER_IMAGE=ghcr.io/daniel-brodsky/protected-file-analyzer-docker-worker:0.1.0

# Runtime paths used inside the containers.
PFA_DATA_ROOT=/data/jobs
PFA_STATIC_DIR=/app/src/protected_file_analyzer/static
PFA_WORDLISTS_DIR=/data/wordlists
PFA_DEFAULT_ROCKYOU_PATH=/data/wordlists/rockyou.txt
PFA_YARA_RULES_PATH=/app/src/protected_file_analyzer/rules/basic_static.yar

# Linux/macOS bind-mount compatibility for the container group.
# Setup scripts can override this with the current host group id.
PFA_RUNTIME_GID=10001

# Backend selection: local or kali_mcp.
PFA_TOOL_RUNNER_BACKEND=local

# Optional Kali MCP compatibility backend.
PFA_KALI_MCP_URL=http://127.0.0.1:5000
PFA_KALI_MCP_WORKER_PYTHON=/usr/bin/python3
PFA_KALI_MCP_WORKER_PATH=/opt/protected-file-analyzer/worker/kali_worker.py

# Extraction limits.
PFA_MAX_EXTRACTED_MB=500
PFA_MAX_EXTRACTED_FILES=5000

# Recovery and worker behavior.
PFA_CRACK_TIMEOUT_SECONDS=120
PFA_MAX_CONCURRENT_CRACKS=1
PFA_WORKER_POLL_INTERVAL_SECONDS=1.0
PFA_CLEANUP_INTERVAL_SECONDS=900
PFA_JOB_TTL_MINUTES=60

# Bounded recovery-policy stages.
PFA_RECOVERY_CUSTOM_TIMEOUT_SECONDS=45
PFA_RECOVERY_CUSTOM_MAX_CANDIDATES=50000
PFA_RECOVERY_MOUNTED_TIMEOUT_SECONDS=45
PFA_RECOVERY_MOUNTED_MAX_CANDIDATES=50000
PFA_RECOVERY_PIN_TIMEOUT_SECONDS=30
PFA_RECOVERY_PIN_MAX_CANDIDATES=10000
PFA_RECOVERY_ROCKYOU_TIMEOUT_SECONDS=60
PFA_RECOVERY_ROCKYOU_MAX_CANDIDATES=200000
PFA_SCOPED_ORG_PATTERNS_ENABLED=0
PFA_SCOPED_ORG_PATTERN_TIMEOUT_SECONDS=30
PFA_SCOPED_ORG_PATTERN_MAX_CANDIDATES=20000
PFA_SCOPED_ORG_ID_PREFIXES=

# Safe raw-output rendering and download limits.
PFA_TOOL_OUTPUT_UI_MAX_BYTES=16384
PFA_TOOL_OUTPUT_DOWNLOAD_MAX_BYTES=262144

# Container resource limits.
PFA_WEB_CPU_LIMIT=1.0
PFA_WEB_MEMORY_LIMIT=768m
PFA_WEB_PIDS_LIMIT=256
PFA_WORKER_CPU_LIMIT=2.0
PFA_WORKER_MEMORY_LIMIT=2g
PFA_WORKER_PIDS_LIMIT=512
