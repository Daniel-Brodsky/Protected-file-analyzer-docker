# Required for normal local use.
PFA_BIND_HOST=127.0.0.1
PFA_BIND_PORT=8088
PFA_SECRET_KEY=change-me

# Application identity.
PFA_APP_NAME=Protected File Analyzer

# Runtime paths used inside the containers.
PFA_DATA_ROOT=/data/jobs
PFA_STATIC_DIR=/app/src/protected_file_analyzer/static
PFA_WORDLISTS_DIR=/data/wordlists
PFA_DEFAULT_ROCKYOU_PATH=/data/wordlists/rockyou.txt
PFA_YARA_RULES_PATH=/app/src/protected_file_analyzer/rules/basic_static.yar

# Linux/macOS bind-mount compatibility for the container group.
# Setup scripts can override this with the current host group id.
PFA_RUNTIME_GID=10001

# Backend selection: local or kali_mcp.
PFA_TOOL_RUNNER_BACKEND=local

# Optional Kali MCP compatibility backend.
PFA_KALI_MCP_URL=http://127.0.0.1:5000
PFA_KALI_MCP_WORKER_PYTHON=/usr/bin/python3
PFA_KALI_MCP_WORKER_PATH=/opt/protected-file-analyzer/worker/kali_worker.py

# Optional upload and extraction limits.
PFA_MAX_FILE_MB=100
PFA_MAX_WORDLIST_MB=200
PFA_MAX_EXTRACTED_MB=500
PFA_MAX_EXTRACTED_FILES=5000

# Optional cracking and worker behavior.
PFA_CRACK_TIMEOUT_SECONDS=120
PFA_MAX_CONCURRENT_CRACKS=1
PFA_WORKER_POLL_INTERVAL_SECONDS=1.0
PFA_CLEANUP_INTERVAL_SECONDS=900
PFA_JOB_TTL_MINUTES=60
PFA_REVEAL_DISPLAY_SECONDS=30

# Optional scanner toggle.
PFA_CLAMAV_ENABLED=1